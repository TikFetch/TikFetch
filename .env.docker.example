SPRING_PROFILES_ACTIVE=production
SERVER_PORT=8080

APP_NAME=TikFetch
APP_BASE_URL=https://tikfetch.despical.dev
APP_STORAGE_DIR=/var/lib/tikfetch/storage
APP_LATEST_VIDEOS_LIMIT=9
APP_RETAINED_SUCCESSFUL_VIDEOS=9
APP_FAILED_ATTEMPT_RETENTION_DAYS=7
APP_CLEANUP_ENABLED=true
APP_CLEANUP_INTERVAL_MS=3600000

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=tikfetch
MYSQL_USERNAME=tikfetch
MYSQL_PASSWORD=change-me
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/tikfetch?createDatabaseIfNotExist=false&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC

JWT_SECRET=change-this-to-a-long-random-secret-at-least-256-bits
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=30

ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

YT_DLP_TIMEOUT_SECONDS=120
YT_DLP_COOKIES_PATH=
YT_DLP_COOKIES_FROM_BROWSER=
YT_DLP_PROXY=
YT_DLP_USER_AGENT=
YT_DLP_EXTRACTOR_ARGS=
YT_DLP_FORMAT=best[vcodec=h264][ext=mp4]/best[ext=mp4]/best
YT_DLP_SOCKET_TIMEOUT_SECONDS=60
YT_DLP_RETRIES=10
YT_DLP_EXTRACTOR_RETRIES=5
YT_DLP_FRAGMENT_RETRIES=10
YT_DLP_RETRY_SLEEP=exp=1:20

COOKIE_SECURE=true

APP_RATE_LIMIT_DOWNLOAD_CAPACITY=10
APP_RATE_LIMIT_DOWNLOAD_REFILL_MINUTES=1
APP_RATE_LIMIT_LOGIN_CAPACITY=5
APP_RATE_LIMIT_LOGIN_REFILL_MINUTES=5
